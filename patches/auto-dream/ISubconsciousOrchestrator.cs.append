/// <summary>
/// 定期记忆整理：扫描 → Flash LLM 分析 → 去重合并 → 过期清理 → 报告。
/// 由 SubconsciousWorkerService 定时触发（每 12h）。
/// </summary>
/// <param name="workspaceId">工作区 ID</param>
/// <param name="memoryLlmConfig">LLM 配置，默认使用 Flash 模型</param>
/// <param name="ct">取消令牌</param>
Task<AutoDreamReport> AutoDreamAsync(
    string workspaceId,
    MemoryLlmConfig? memoryLlmConfig = null,
    CancellationToken ct = default);
