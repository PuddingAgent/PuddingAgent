<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PuddingAssistantDesktop.ViewModels"
             xmlns:m="using:PuddingAssistantDesktop.Models"
             x:Class="PuddingAssistantDesktop.Views.EditorView"
             x:DataType="vm:MainWindowViewModel"
             Background="#1E1E1E">

  <UserControl.Styles>
    <!-- Activity bar icon -->
    <Style Selector="Button.act-icon">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#858585"/>
      <Setter Property="Width" Value="48"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.act-icon:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A2D2E"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Sidebar section header -->
    <Style Selector="TextBlock.sidebar-header">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#BBBBBB"/>
      <Setter Property="Padding" Value="12,8,12,4"/>
    </Style>

    <!-- Panel tab button -->
    <Style Selector="Button.panel-tab">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#858585"/>
      <Setter Property="Padding" Value="12,4"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="BorderThickness" Value="0,0,0,2"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
    </Style>
    <Style Selector="Button.panel-tab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A2D2E"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Dark text box -->
    <Style Selector="TextBox.dark-input">
      <Setter Property="Background" Value="#1E1E1E"/>
      <Setter Property="Foreground" Value="#CCCCCC"/>
      <Setter Property="BorderBrush" Value="#3C3C3C"/>
      <Setter Property="CaretBrush" Value="#AEAFAD"/>
      <Setter Property="FontFamily" Value="Consolas,monospace"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- Send / action button -->
    <Style Selector="Button.action-btn">
      <Setter Property="Background" Value="#0E639C"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="Padding" Value="12,4"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.action-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1177BB"/>
    </Style>
    <Style Selector="Button.action-btn:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#3C3C3C"/>
      <Setter Property="Foreground" Value="#666"/>
    </Style>

    <Style Selector="ListBox">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="#094771"/>
    </Style>
    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2A2D2E"/>
    </Style>
  </UserControl.Styles>

  <DockPanel>

    <!-- 鈺愨晲鈺?ACTIVITY BAR (left icon strip, 48px) 鈺愨晲鈺?-->
    <Border DockPanel.Dock="Left" Width="48" Background="#333333">
      <StackPanel>
        <Button Classes="act-icon" Content="&#x1F4C1;"
                Command="{Binding ToggleSidebarCommand}" CommandParameter="Explorer"
                ToolTip.Tip="Explorer"/>
        <Button Classes="act-icon" Content="&#x1F50D;"
                Command="{Binding ToggleSidebarCommand}" CommandParameter="Search"
                ToolTip.Tip="Search"/>
        <Button Classes="act-icon" Content="&#x1F500;"
                Command="{Binding ToggleSidebarCommand}" CommandParameter="Git"
                ToolTip.Tip="Source Control"/>
      </StackPanel>
    </Border>

    <!-- 鈺愨晲鈺?SIDEBAR (collapsible, 260px) 鈺愨晲鈺?-->
    <Border DockPanel.Dock="Left" Width="260" Background="#252526"
            BorderBrush="#1E1E1E" BorderThickness="0,0,1,0"
            IsVisible="{Binding IsSidebarVisible}">
      <DockPanel>
        <!-- Sidebar header -->
        <Border DockPanel.Dock="Top" Padding="12,6" Background="#252526">
          <DockPanel>
            <TextBlock Text="EXPLORER" FontSize="11" FontWeight="SemiBold"
                       Foreground="#BBBBBB" VerticalAlignment="Center"
                       IsVisible="{Binding IsSidebarExplorer}"/>
            <TextBlock Text="SEARCH" FontSize="11" FontWeight="SemiBold"
                       Foreground="#BBBBBB" VerticalAlignment="Center"
                       IsVisible="{Binding IsSidebarSearch}"/>
            <TextBlock Text="SOURCE CONTROL" FontSize="11" FontWeight="SemiBold"
                       Foreground="#BBBBBB" VerticalAlignment="Center"
                       IsVisible="{Binding IsSidebarGit}"/>
          </DockPanel>
        </Border>

        <!-- Explorer panel -->
        <DockPanel IsVisible="{Binding IsSidebarExplorer}">
          <!-- Project files -->
          <Border DockPanel.Dock="Top" Padding="0">
            <DockPanel>
              <TextBlock Classes="sidebar-header" DockPanel.Dock="Top"
                         Text="{Binding ProjectDisplayName}"/>
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding ProjectTree}" Margin="4,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding}" FontSize="12" Foreground="#CCCCCC"
                                 Padding="4,2" FontFamily="Consolas,monospace"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </DockPanel>
          </Border>
        </DockPanel>

        <!-- Search panel (placeholder) -->
        <StackPanel IsVisible="{Binding IsSidebarSearch}" Margin="12,8">
          <TextBox Watermark="Search..." Classes="dark-input" Margin="0,0,0,8"/>
          <TextBlock Text="Type to search across files" FontSize="11" Foreground="#666"/>
        </StackPanel>

        <!-- Git panel (placeholder) -->
        <StackPanel IsVisible="{Binding IsSidebarGit}" Margin="12,8">
          <TextBlock Text="&#x1F500; master" FontSize="13" Foreground="#CCC" Margin="0,0,0,8"/>
          <TextBlock Text="No pending changes" FontSize="11" Foreground="#666"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- 鈺愨晲鈺?EDITOR + BOTTOM PANEL 鈺愨晲鈺?-->
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" MinHeight="120"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto" MinHeight="0"/>
      </Grid.RowDefinitions>

      <!-- 鈹€鈹€鈹€ EDITOR AREA (top) 鈹€鈹€鈹€ -->
      <DockPanel Grid.Row="0">
        <!-- Tab bar -->
        <Border DockPanel.Dock="Top" Background="#252526" Padding="0" Height="35">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding OpenEditors}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="12,8" Background="#1E1E1E"
                          BorderBrush="#1E1E1E" BorderThickness="1,0,1,0">
                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#CCCCCC"/>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <!-- Editor content -->
        <Border Background="#1E1E1E" Padding="16">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="&#x1F4DD;" FontSize="48" HorizontalAlignment="Center" Foreground="#555"/>
            <TextBlock Text="PuddingAssistant Editor" FontSize="16" Foreground="#666" HorizontalAlignment="Center"/>
            <TextBlock Text="Open a folder to start" FontSize="12" Foreground="#555" HorizontalAlignment="Center"/>
            <Button Content="Open Folder..." Command="{Binding OpenFolderCommand}"
                    Classes="action-btn" HorizontalAlignment="Center" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>
      </DockPanel>

      <!-- 鈹€鈹€鈹€ SPLITTER 鈹€鈹€鈹€ -->
      <GridSplitter Grid.Row="1" Height="4" Background="#252526"
                    ResizeDirection="Rows"
                    IsVisible="{Binding IsBottomPanelVisible}"/>

      <!-- 鈹€鈹€鈹€ BOTTOM PANEL (Chat / Output / Problems) 鈹€鈹€鈹€ -->
      <Border Grid.Row="2" Background="#1E1E1E" Height="280"
              IsVisible="{Binding IsBottomPanelVisible}">
        <DockPanel>
          <!-- Panel tab bar -->
          <Border DockPanel.Dock="Top" Background="#252526" Height="30"
                  BorderBrush="#1E1E1E" BorderThickness="0,1,0,0">
            <DockPanel>
              <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Classes="panel-tab" Content="CHAT &#x1F4AC;"
                        Command="{Binding SwitchBottomPanelCommand}" CommandParameter="Chat"/>
                <Button Classes="panel-tab" Content="OUTPUT"
                        Command="{Binding SwitchBottomPanelCommand}" CommandParameter="Output"/>
                <Button Classes="panel-tab" Content="PROBLEMS"
                        Command="{Binding SwitchBottomPanelCommand}" CommandParameter="Problems"/>
              </StackPanel>
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="0,0,4,0">
                <Button Classes="panel-tab" Content="&#x2715;"
                        Command="{Binding ToggleBottomPanelCommand}"
                        ToolTip.Tip="Close Panel"/>
              </StackPanel>
              <Panel/>
            </DockPanel>
          </Border>

          <!-- Chat panel -->
          <DockPanel IsVisible="{Binding IsBottomChat}">
            <!-- Input bar -->
            <Border DockPanel.Dock="Bottom" Padding="8" Background="#252526"
                    BorderBrush="#3C3C3C" BorderThickness="0,1,0,0">
              <DockPanel>
                <Button DockPanel.Dock="Right" Content="Send" Classes="action-btn"
                        Command="{Binding SendMessageCommand}" Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right" Content="Cancel" Classes="panel-tab"
                        Command="{Binding CancelAgentCommand}" IsVisible="{Binding IsBusy}" Margin="4,0,0,0"/>
                <TextBox Text="{Binding UserInput}" Classes="dark-input"
                         Watermark="Ask PuddingAssistant anything..." AcceptsReturn="False"/>
              </DockPanel>
            </Border>
            <!-- Message list -->
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="8,4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:ChatEntry">
                    <Border Margin="0,2" Padding="8,4" CornerRadius="4" Background="#252526">
                      <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding Icon}" FontSize="14"
                                   Margin="0,0,8,0" VerticalAlignment="Top"/>
                        <SelectableTextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                             FontFamily="Consolas,monospace" FontSize="12.5"
                                             Foreground="#CCCCCC"/>
                      </DockPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>

          <!-- Output panel -->
          <Border IsVisible="{Binding IsBottomOutput}" Background="#1E1E1E" Padding="8">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding LogEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <SelectableTextBlock Text="{Binding}" Foreground="#CCCCCC" TextWrapping="Wrap"
                                         FontFamily="Consolas,monospace" FontSize="11"
                                         Margin="0,1"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>

          <!-- Problems panel -->
          <Border IsVisible="{Binding IsBottomProblems}" Background="#1E1E1E" Padding="8">
            <StackPanel>
              <TextBlock Text="No problems detected" FontSize="12" Foreground="#666"
                         IsVisible="{Binding !Problems.Count}"/>
              <ItemsControl ItemsSource="{Binding Problems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="#F48771" FontFamily="Consolas,monospace"
                               FontSize="12" Margin="0,2"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>
        </DockPanel>
      </Border>
    </Grid>

  </DockPanel>
</UserControl>