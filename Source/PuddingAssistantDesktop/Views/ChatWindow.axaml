<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PuddingAssistantDesktop.ViewModels"
        xmlns:m="using:PuddingAssistantDesktop.Models"
        x:Class="PuddingAssistantDesktop.Views.ChatWindow"
        x:DataType="vm:ChatWindowViewModel"
        Title="Pudding Chat"
        Width="720" Height="820"
        MinWidth="480" MinHeight="560"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        SystemDecorations="BorderOnly"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="True"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <Style Selector="Border.msg-user">
      <Setter Property="Background" Value="#3A2A5A"/>
      <Setter Property="CornerRadius" Value="14,14,4,14"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="MaxWidth" Value="480"/>
    </Style>
    <Style Selector="Border.msg-agent">
      <Setter Property="Background" Value="#2A2A44"/>
      <Setter Property="CornerRadius" Value="14,14,14,4"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="MaxWidth" Value="480"/>
    </Style>
    <Style Selector="Border.reasoning">
      <Setter Property="Background" Value="#1A2A24"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Opacity" Value="0.9"/>
    </Style>
    <!-- Scrollbar visibility on dark background -->
    <Style Selector="ScrollViewer#MessageScroll /template/ ScrollBar">
      <Setter Property="Opacity" Value="0.7"/>
    </Style>
    <Style Selector="ScrollViewer#MessageScroll /template/ ScrollBar:pointerover">
      <Setter Property="Opacity" Value="1.0"/>
    </Style>
    <!-- Input box: penetrate Fluent theme template in ALL states -->
    <Style Selector="TextBox#ChatInput">
      <Setter Property="Foreground" Value="#F5F5FF"/>
      <Setter Property="CaretBrush" Value="#E8D0FF"/>
      <Setter Property="SelectionBrush" Value="#445588"/>
    </Style>
    <!-- Template Border: controls actual visible bg/border in all states -->
    <Style Selector="TextBox#ChatInput /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#0A0A18"/>
      <Setter Property="BorderBrush" Value="#555577"/>
    </Style>
    <Style Selector="TextBox#ChatInput:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#0E0E20"/>
      <Setter Property="BorderBrush" Value="#6644AA"/>
    </Style>
    <Style Selector="TextBox#ChatInput:focus /template/ Border#PART_BorderElement">
      <Setter Property="Background" Value="#0A0A18"/>
      <Setter Property="BorderBrush" Value="#7755AA"/>
    </Style>
    <!-- TextPresenter: the element that actually renders typed text -->
    <Style Selector="TextBox#ChatInput /template/ TextPresenter#PART_TextPresenter">
      <Setter Property="CaretBrush" Value="#E8D0FF"/>
    </Style>
    <Style Selector="TextBox#ChatInput:focus /template/ TextPresenter#PART_TextPresenter">
      <Setter Property="CaretBrush" Value="#E8D0FF"/>
    </Style>
    <!-- Watermark placeholder -->
    <Style Selector="TextBox#ChatInput /template/ TextBlock#PART_Watermark">
      <Setter Property="Foreground" Value="#667788"/>
    </Style>
  </Window.Styles>

  <Border Background="#E61A1A2E" CornerRadius="14" ClipToBounds="True"
          BorderBrush="#40FFFFFF" BorderThickness="1">
    <Grid RowDefinitions="Auto,*,Auto">

      <Border Grid.Row="0" Background="#F016162A" Padding="16,12"
              x:Name="TitleBar" PointerPressed="OnTitleBarPointerPressed">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <TextBlock Grid.Column="0" Text="&#x1F36E;" FontSize="20"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" Text="Pudding Chat" Foreground="#E0D0EE"
                     FontSize="16" FontWeight="SemiBold" Margin="10,0,0,0"
                     VerticalAlignment="Center"/>
          <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                     Foreground="#888899" FontSize="11"
                     VerticalAlignment="Center" Margin="0,0,12,0"/>
          <Button Grid.Column="3" Content="&#x2715;" FontSize="15"
                  Background="Transparent" Foreground="#888899"
                  Padding="10,4" CornerRadius="8"
                  Click="OnCloseClicked" VerticalAlignment="Center"/>
        </Grid>
      </Border>

      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                    Padding="10,8" x:Name="MessageScroll">
        <ItemsControl ItemsSource="{Binding Messages}" Margin="0,0,0,14">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="m:ChatEntry">
              <Grid Margin="0,4">
                <!-- USER message: right-aligned -->
                <DockPanel HorizontalAlignment="Right" IsVisible="{Binding IsUser}">
                  <TextBlock DockPanel.Dock="Right" Text="{Binding Icon}"
                             FontSize="18" VerticalAlignment="Top"
                             Margin="10,8,4,0"/>
                  <Border Classes="msg-user">
                    <TextBlock Text="{Binding Content}" Foreground="#EEEEFF"
                               FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
                  </Border>
                </DockPanel>

                <!-- AGENT message: left-aligned -->
                <DockPanel HorizontalAlignment="Left" IsVisible="{Binding !IsUser}">
                  <TextBlock DockPanel.Dock="Left" Text="{Binding Icon}"
                             FontSize="18" VerticalAlignment="Top"
                             Margin="4,8,10,0"/>
                  <Border Classes="msg-agent">
                    <StackPanel>
                      <Border Classes="reasoning" IsVisible="{Binding HasReasoning}">
                        <StackPanel>
                          <TextBlock Text="&#x1F4AD; Thinking..." Foreground="#77AA88"
                                     FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                          <TextBlock Text="{Binding ReasoningContent}" Foreground="#99BBAA"
                                     FontSize="12.5" TextWrapping="Wrap" LineHeight="18"
                                     MaxHeight="200"/>
                        </StackPanel>
                      </Border>
                      <TextBlock Text="{Binding Content}" Foreground="#DDDDEE"
                                 FontSize="14" TextWrapping="Wrap" LineHeight="22"/>
                    </StackPanel>
                  </Border>
                </DockPanel>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Input area: multi-line + attachment + high contrast -->
      <Border Grid.Row="2" Background="#F016162A" Padding="12,8"
              CornerRadius="0,0,14,14">
        <DockPanel>
          <!-- Button row: attach / paste / send -->
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                      HorizontalAlignment="Right" Margin="0,6,0,0" Spacing="6">
            <Button Content="&#x1F4CE; Attach" Padding="10,6" CornerRadius="8"
                    Background="#2E2E4A" Foreground="#BBBBDD" FontSize="12"
                    Click="OnAttachClicked" ToolTip.Tip="Attach file (image, doc, etc.)"/>
            <Button Content="&#x1F4CB; Paste" Padding="10,6" CornerRadius="8"
                    Background="#2E2E4A" Foreground="#BBBBDD" FontSize="12"
                    Click="OnPasteClicked" ToolTip.Tip="Paste from clipboard"/>
            <Button Content="Send" Command="{Binding SendCommand}"
                    Padding="18,6" CornerRadius="8"
                    Background="#6A4A9A" Foreground="#F0E8FF"
                    FontSize="13" FontWeight="SemiBold"
                    ToolTip.Tip="Enter to send, Shift+Enter for new line"/>
          </StackPanel>

          <!-- Attachment preview bar (shown when files are attached) -->
          <ItemsControl DockPanel.Dock="Bottom"
                        ItemsSource="{Binding Attachments}"
                        IsVisible="{Binding HasAttachments}"
                        Margin="0,4,0,0">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:AttachmentItem">
                <Border Background="#2E2E4A" CornerRadius="6" Padding="8,4"
                        Margin="0,0,6,4">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Icon}" FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DisplayName}" Foreground="#CCCCEE"
                               FontSize="11" VerticalAlignment="Center" MaxWidth="120"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Content="&#x2715;" FontSize="10" Padding="4,2" CornerRadius="4"
                            Background="Transparent" Foreground="#888899"
                            Command="{Binding RemoveCommand}"
                            VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Multi-line text input with high contrast -->
          <TextBox Text="{Binding InputText, Mode=TwoWay}"
                   Watermark="Message... (Enter send, Shift+Enter new line)"
                   AcceptsReturn="True" TextWrapping="Wrap"
                   MaxHeight="120" MinHeight="38"
                   Background="#0A0A18" Foreground="#F5F5FF"
                   CaretBrush="#E8D0FF"
                   BorderThickness="1" BorderBrush="#555577"
                   CornerRadius="10" Padding="14,10" FontSize="14"
                   x:Name="ChatInput"
                   DragDrop.AllowDrop="True"/>
        </DockPanel>
      </Border>

    </Grid>
  </Border>
</Window>
