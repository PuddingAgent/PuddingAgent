<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PuddingAssistantDesktop.ViewModels"
        xmlns:m="using:PuddingAssistantDesktop.Models"
        xmlns:v="using:PuddingAssistantDesktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="PuddingAssistantDesktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PuddingAssistant - Swarm IDE"
        Width="1280" Height="800"
        Background="#1E1E1E">

  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="Button.menu-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#CCCCCC"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.menu-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#505050"/>
    </Style>
    <Style Selector="Button.status-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="Padding" Value="6,0"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.status-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1B8CD8"/>
    </Style>
    <Style Selector="Button.view-pill">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#999"/>
      <Setter Property="Padding" Value="10,3"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.view-pill:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#505050"/>
    </Style>
  </Window.Styles>

  <DockPanel LastChildFill="True">

    <!-- MENU BAR -->
    <Border DockPanel.Dock="Top" Background="#333333" Height="30">
      <DockPanel Margin="4,0">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
          <Button Classes="menu-btn" Content="File" Command="{Binding OpenFolderCommand}" ToolTip.Tip="Open Folder..."/>
          <Button Classes="menu-btn" Content="Edit" IsEnabled="False"/>
          <Button Classes="menu-btn" Content="View" IsEnabled="False"/>
          <Button Classes="menu-btn" Content="Terminal" IsEnabled="False"/>
          <Button Classes="menu-btn" Content="Help" IsEnabled="False"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="6" Margin="0,0,4,0">
          <ComboBox ItemsSource="{Binding Providers}" SelectedItem="{Binding ActiveProvider}"
                    Width="180" FontSize="11" Background="#3C3C3C" Foreground="#CCC"
                    VerticalAlignment="Center" Padding="4,2">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="m:ProviderInfo">
                <TextBlock Text="{Binding}" FontSize="11"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Border Background="#4A4A4A" CornerRadius="3" Padding="1" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="0">
              <Button Classes="view-pill" Content="Editor"
                      Command="{Binding SwitchToEditorCommand}"
                      FontWeight="{Binding EditorButtonWeight}"/>
              <Button Classes="view-pill" Content="Swarm"
                      Command="{Binding SwitchToSwarmCommand}"
                      FontWeight="{Binding SwarmButtonWeight}"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <TextBlock Text="{Binding ProjectDisplayName}" FontSize="12"
                   Foreground="#999" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </DockPanel>
    </Border>

    <!-- STATUS BAR -->
    <Border DockPanel.Dock="Bottom" Background="#007ACC" Height="22">
      <DockPanel>
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
          <Button Classes="status-btn" Content="&#x1F4C2;" Command="{Binding OpenFolderCommand}" ToolTip.Tip="Open Folder"/>
          <Button Classes="status-btn" Content="&#x1F500; master" IsEnabled="False" ToolTip.Tip="Git Branch"/>
          <Button Classes="status-btn" Content="&#x26A0; 0  &#x2715; 0" IsEnabled="False" ToolTip.Tip="Problems"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Classes="status-btn" Content="{Binding ActiveProvider.Model}" IsEnabled="False" ToolTip.Tip="Active Model"/>
          <Button Classes="status-btn" Content="{Binding StatusText}" IsEnabled="False"/>
        </StackPanel>
        <Panel/>
      </DockPanel>
    </Border>

    <!-- MAIN CONTENT -->
    <Panel>
      <v:EditorView IsVisible="{Binding IsEditorView}"/>
      <v:SwarmView IsVisible="{Binding IsSwarmView}"/>
    </Panel>

  </DockPanel>
</Window>