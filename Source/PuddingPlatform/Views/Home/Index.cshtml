@{
    ViewData["Title"] = "Pudding Platform";
}

<div class="text-center">
    <h1 class="display-4">Pudding Agent Network</h1>
    <p class="lead">管理工作空间、会话与 Agent 网络的控制面板。</p>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">工作空间</h5>
                <p class="card-text">管理 Workspace、渠道绑定和 Agent 模板。</p>
                <a asp-controller="Workspace" asp-action="Index" class="btn btn-primary">查看工作空间</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">会话</h5>
                <p class="card-text">查看当前活跃的 Session 和历史记录。</p>
                <a asp-controller="Session" asp-action="Index" class="btn btn-primary">查看会话</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">发送消息</h5>
                <p class="card-text">通过 Platform 界面发送消息到 Agent。</p>
                <a asp-controller="Chat" asp-action="Index" class="btn btn-primary">开始对话</a>
            </div>
        </div>
    </div>
</div>
