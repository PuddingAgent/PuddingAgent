<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:PuddingCodeDesktop.ViewModels" xmlns:m="using:PuddingCodeDesktop.Models" x:Class="PuddingCodeDesktop.Views.SwarmView" x:DataType="vm:MainWindowViewModel" Background="#1A1A2E"><UserControl.Styles><Style Selector="Border.pulse"><Style.Animations><Animation Duration="0:0:1.5" IterationCount="INFINITE"><KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame><KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.3"/></KeyFrame><KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame></Animation></Style.Animations></Style><Style Selector="Border.glow-breathe"><Style.Animations><Animation Duration="0:0:2" IterationCount="INFINITE"><KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.85"/></KeyFrame><KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame><KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.85"/></KeyFrame></Animation></Style.Animations></Style><Style Selector="Border.bubble-float"><Style.Animations><Animation Duration="0:0:0.4" FillMode="Forward"><KeyFrame Cue="0%"><Setter Property="Opacity" Value="0"/></KeyFrame><KeyFrame Cue="100%"><Setter Property="Opacity" Value="1"/></KeyFrame></Animation></Style.Animations></Style><Style Selector="ListBox"><Setter Property="Background" Value="Transparent"/></Style><Style Selector="ListBoxItem:selected /template/ ContentPresenter"><Setter Property="Background" Value="#2A2A4A"/></Style><Style Selector="ListBoxItem:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#222240"/></Style><Style Selector="Button.cmd"><Setter Property="Background" Value="#2A2A4A"/><Setter Property="Foreground" Value="#CCC"/><Setter Property="CornerRadius" Value="4"/><Setter Property="Padding" Value="10,5"/><Setter Property="FontSize" Value="11"/></Style><Style Selector="Button.cmd:pointerover /template/ ContentPresenter"><Setter Property="Background" Value="#3A3A5A"/></Style><Style Selector="Button.cmd-danger"><Setter Property="Background" Value="#3A1A1A"/><Setter Property="Foreground" Value="#F88"/><Setter Property="CornerRadius" Value="4"/><Setter Property="Padding" Value="10,5"/><Setter Property="FontSize" Value="11"/></Style><Style Selector="Button.cmd-primary"><Setter Property="Background" Value="#1A3A2A"/><Setter Property="Foreground" Value="#8F8"/><Setter Property="CornerRadius" Value="4"/><Setter Property="Padding" Value="10,5"/><Setter Property="FontSize" Value="11"/></Style><Style Selector="Button.bubble-btn"><Setter Property="Background" Value="Transparent"/><Setter Property="Padding" Value="0"/><Setter Property="Margin" Value="0"/></Style><Style Selector="TextBox.dark"><Setter Property="Background" Value="#0D0D1A"/><Setter Property="Foreground" Value="#DDD"/><Setter Property="BorderBrush" Value="#333355"/><Setter Property="CaretBrush" Value="#F5A623"/></Style></UserControl.Styles><DockPanel><Border DockPanel.Dock="Left" Width="220" Background="#16213E" BorderBrush="#2A2A4A" BorderThickness="0,0,1,0"><DockPanel><Border DockPanel.Dock="Top" Padding="12,10" Background="#0F3460"><DockPanel><TextBlock Text="&#x1F41D; Agents" FontWeight="Bold" FontSize="13" Foreground="#E0E0E0" VerticalAlignment="Center"/><Button DockPanel.Dock="Right" Content="+ Worker" Classes="cmd-primary" Command="{Binding SpawnWorkerCommand}" FontSize="10" Padding="6,3" HorizontalAlignment="Right"/></DockPanel></Border><ListBox ItemsSource="{Binding SwarmAgents}" SelectedItem="{Binding SelectedSwarmAgent}" Margin="4"><ListBox.ItemTemplate><DataTemplate x:DataType="m:SwarmAgent"><Border Padding="8,6" Margin="2" CornerRadius="6" Background="#1A1A3E" Opacity="{Binding StatusOpacity}" BorderThickness="1" BorderBrush="{Binding BorderColor}"><DockPanel><Border DockPanel.Dock="Left" Width="10" Height="10" CornerRadius="5" Background="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,8,0" Classes="pulse"/><StackPanel Spacing="1"><StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="{Binding RoleIcon}" FontSize="12"/><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" Foreground="#E0E0E0"/><Border CornerRadius="7" Background="#D0021B" MinWidth="14" Height="14" Padding="3,0" Margin="4,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" IsVisible="{Binding HasUnread}"><TextBlock Text="{Binding UnreadBadge}" FontSize="9" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></StackPanel><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="{Binding StatusColor}"/><TextBlock Text="{Binding Model}" FontSize="10" Foreground="#556"/></StackPanel><TextBlock Text="{Binding CurrentTask}" FontSize="9" Foreground="#667" TextTrimming="CharacterEllipsis" IsVisible="{Binding CurrentTask, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/></StackPanel></DockPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox></DockPanel></Border><Border DockPanel.Dock="Right" Width="270" Background="#16213E" BorderBrush="#2A2A4A" BorderThickness="1,0,0,0"><DockPanel><Border DockPanel.Dock="Top" Padding="12,10" Background="#0F3460"><TextBlock Text="&#x1F4CB; Detail" FontWeight="Bold" FontSize="13" Foreground="#E0E0E0"/></Border><ScrollViewer Margin="10,8"><StackPanel Spacing="10" IsVisible="{Binding SelectedSwarmAgent, Converter={x:Static ObjectConverters.IsNotNull}}"><Border Padding="12" CornerRadius="8" Background="#1A1A3E" BorderThickness="1" BorderBrush="{Binding SelectedSwarmAgent.BorderColor}"><StackPanel Spacing="8"><StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="{Binding SelectedSwarmAgent.RoleIcon}" FontSize="22"/><StackPanel><TextBlock Text="{Binding SelectedSwarmAgent.DisplayName}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F0"/><TextBlock Text="{Binding SelectedSwarmAgent.Role}" FontSize="11" Foreground="#888"/></StackPanel></StackPanel><Border Padding="8,5" CornerRadius="4" Background="{Binding SelectedSwarmAgent.GlowColor}"><StackPanel Orientation="Horizontal" Spacing="6"><Border Width="8" Height="8" CornerRadius="4" Background="{Binding SelectedSwarmAgent.StatusColor}" Classes="pulse"/><TextBlock Text="{Binding SelectedSwarmAgent.StatusLabel}" Foreground="#E0E0E0" FontWeight="SemiBold" FontSize="12"/></StackPanel></Border><StackPanel Spacing="4"><DockPanel><TextBlock Text="Model" Width="55" FontSize="11" Foreground="#778"/><TextBlock Text="{Binding SelectedSwarmAgent.Model}" FontSize="11" Foreground="#BCC" FontFamily="Consolas,monospace"/></DockPanel><DockPanel><TextBlock Text="Task" Width="55" FontSize="11" Foreground="#778"/><TextBlock Text="{Binding SelectedSwarmAgent.CurrentTask}" FontSize="11" Foreground="#BCC" TextWrapping="Wrap"/></DockPanel><DockPanel><TextBlock Text="Tokens" Width="55" FontSize="11" Foreground="#778"/><TextBlock Text="{Binding SelectedSwarmAgent.TokensUsed}" FontSize="11" Foreground="#F5A623" FontFamily="Consolas,monospace"/></DockPanel></StackPanel></StackPanel></Border><TextBlock Text="COMMANDS" FontSize="10" Foreground="#556" FontWeight="Bold" Margin="0,4,0,0" LetterSpacing="2"/><WrapPanel><Button Content="&#x23F8; Pause" Classes="cmd" Command="{Binding PauseAgentCommand}" Margin="0,0,4,4"/><Button Content="&#x25B6; Resume" Classes="cmd-primary" Command="{Binding ResumeAgentCommand}" Margin="0,0,4,4"/><Button Content="&#x2715; Kill" Classes="cmd-danger" Command="{Binding KillAgentCommand}" Margin="0,0,4,4"/></WrapPanel><TextBlock Text="ASSIGN TASK" FontSize="10" Foreground="#556" FontWeight="Bold" Margin="0,4,0,0" LetterSpacing="2"/><Button Content="&#x1F4DD; Open Task Editor..." Classes="cmd-primary" Command="{Binding OpenTaskInputOverlayCommand}" HorizontalAlignment="Stretch" FontSize="11" Padding="10,8" Margin="0,4,0,0"/><TextBlock Text="SEND MESSAGE" FontSize="10" Foreground="#556" FontWeight="Bold" Margin="0,8,0,0" LetterSpacing="2"/><Button Content="&#x1F4AC; Open Message Editor..." Classes="cmd-primary" Command="{Binding OpenMessageInputOverlayCommand}" HorizontalAlignment="Stretch" FontSize="11" Padding="10,8" Margin="0,4,0,0"/><TextBlock Text="MESSAGES" FontSize="10" Foreground="#556" FontWeight="Bold" Margin="0,8,0,0" LetterSpacing="2"/><DockPanel Margin="0,2,0,0"><Button DockPanel.Dock="Right" Content="Mark Read" Classes="cmd" Command="{Binding OpenAgentHistoryCommand}" FontSize="9" Padding="6,2"/><TextBlock Text="unread" FontSize="10" Foreground="#778" VerticalAlignment="Center"/></DockPanel><ItemsControl ItemsSource="{Binding SelectedSwarmAgent.MessageHistory}" Margin="0,4,0,0"><ItemsControl.ItemTemplate><DataTemplate x:DataType="m:SwarmBubble"><Button Classes="bubble-btn" Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenBubbleReaderCommand}" CommandParameter="{Binding}"><Border Padding="8,6" Margin="0,2" CornerRadius="6" Background="{Binding BubbleBg}" BorderThickness="1" BorderBrush="{Binding BubbleBorder}" Cursor="Hand"><StackPanel Spacing="2"><StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="{Binding KindIcon}" FontSize="10"/><TextBlock Text="{Binding SenderName}" FontSize="10" FontWeight="SemiBold" Foreground="#AAA"/><TextBlock Text="{Binding TimeLabel}" FontSize="9" Foreground="#556" Margin="4,0,0,0"/></StackPanel><TextBlock Text="{Binding Preview}" FontSize="10" Foreground="#CCC" TextTrimming="CharacterEllipsis"/></StackPanel></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></ScrollViewer></DockPanel></Border><DockPanel><Border DockPanel.Dock="Bottom" Padding="10,8" Background="#0D0D1A" BorderBrush="#2A2A4A" BorderThickness="0,1,0,0" Height="160"><DockPanel><DockPanel DockPanel.Dock="Top" Margin="0,0,0,6"><TextBlock Text="&#x1F4E1; EVENT LOG" FontWeight="Bold" FontSize="10" Foreground="#556" LetterSpacing="2"/><Button DockPanel.Dock="Right" Content="&#x25B6; Simulate" Classes="cmd-primary" Command="{Binding SimulateSwarmCommand}" HorizontalAlignment="Right" FontSize="10" Padding="8,3"/></DockPanel><ScrollViewer><ItemsControl ItemsSource="{Binding SwarmEventLog}"><ItemsControl.ItemTemplate><DataTemplate><SelectableTextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Consolas,monospace" FontSize="11" Foreground="#7A7A9A" Margin="0,1"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></DockPanel></Border><Panel Background="#12122A"><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="20"><StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0"><TextBlock Text="SWARM TOPOLOGY" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" Foreground="#445" LetterSpacing="3" Margin="0,0,0,24"/><ItemsControl ItemsSource="{Binding LeaderAgents}"><ItemsControl.ItemTemplate><DataTemplate x:DataType="m:SwarmAgent"><StackPanel HorizontalAlignment="Center"><Button Classes="bubble-btn" Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenBubbleReaderCommand}" CommandParameter="{Binding ActiveBubble}" IsVisible="{Binding HasActiveBubble}"><Border Padding="8,5" CornerRadius="8" Background="{Binding ActiveBubble.BubbleBg}" BorderThickness="1" BorderBrush="{Binding ActiveBubble.BubbleBorder}" HorizontalAlignment="Center" Margin="0,0,0,6" MaxWidth="220" Cursor="Hand" Classes="bubble-float"><StackPanel Spacing="1"><StackPanel Orientation="Horizontal" Spacing="3"><TextBlock Text="{Binding ActiveBubble.KindIcon}" FontSize="10"/><TextBlock Text="{Binding ActiveBubble.SenderName}" FontSize="9" Foreground="#AAA" FontWeight="SemiBold"/></StackPanel><TextBlock Text="{Binding ActiveBubble.Preview}" FontSize="10" Foreground="#DDD" TextTrimming="CharacterEllipsis"/></StackPanel></Border></Button><Border Padding="20,14" CornerRadius="10" Background="#1A1A3E" BorderThickness="2" BorderBrush="{Binding BorderColor}" HorizontalAlignment="Center" MinWidth="200" Classes="glow-breathe" Opacity="{Binding StatusOpacity}"><StackPanel HorizontalAlignment="Center" Spacing="6"><StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center"><TextBlock Text="{Binding RoleIcon}" FontSize="20"/><TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="16" Foreground="#F0F0F0"/><Border CornerRadius="7" Background="#D0021B" MinWidth="14" Height="14" Padding="3,0" VerticalAlignment="Top" Margin="-2,-4,0,0" IsVisible="{Binding HasUnread}"><TextBlock Text="{Binding UnreadBadge}" FontSize="8" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></StackPanel><Border Padding="6,3" CornerRadius="4" HorizontalAlignment="Center" Background="{Binding GlowColor}"><StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"><Border Width="8" Height="8" CornerRadius="4" Background="{Binding StatusColor}" Classes="pulse"/><TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="#DDD"/></StackPanel></Border><TextBlock Text="{Binding Model}" FontSize="11" Foreground="#667" HorizontalAlignment="Center" FontFamily="Consolas,monospace"/><TextBlock Text="{Binding CurrentTask}" FontSize="10" Foreground="#889" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="180" IsVisible="{Binding CurrentTask, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/></StackPanel></Border></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><Border Height="32" Width="2" Background="#333355" HorizontalAlignment="Center" IsVisible="{Binding HasWorkers}"/><Border Height="2" Background="#333355" Margin="40,0" HorizontalAlignment="Stretch" IsVisible="{Binding HasWorkers}"/><ItemsControl ItemsSource="{Binding WorkerAgents}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Center"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="m:SwarmAgent"><StackPanel Margin="10,0" HorizontalAlignment="Center"><Border Width="2" Height="14" HorizontalAlignment="Center" Background="{Binding ConnectorColor}"/><StackPanel><Button Classes="bubble-btn" Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenBubbleReaderCommand}" CommandParameter="{Binding ActiveBubble}" IsVisible="{Binding HasActiveBubble}" HorizontalAlignment="Center"><Border Padding="6,4" CornerRadius="6" Background="{Binding ActiveBubble.BubbleBg}" BorderThickness="1" BorderBrush="{Binding ActiveBubble.BubbleBorder}" HorizontalAlignment="Center" Margin="0,0,0,4" MaxWidth="180" Cursor="Hand" Classes="bubble-float"><StackPanel Spacing="1"><StackPanel Orientation="Horizontal" Spacing="3"><TextBlock Text="{Binding ActiveBubble.KindIcon}" FontSize="9"/><TextBlock Text="{Binding ActiveBubble.SenderName}" FontSize="8" Foreground="#AAA" FontWeight="SemiBold"/></StackPanel><TextBlock Text="{Binding ActiveBubble.Preview}" FontSize="9" Foreground="#DDD" TextTrimming="CharacterEllipsis"/></StackPanel></Border></Button><Border Padding="14,10" CornerRadius="8" Background="#1A1A3E" BorderThickness="1.5" BorderBrush="{Binding BorderColor}" MinWidth="150" Classes="glow-breathe" Opacity="{Binding StatusOpacity}"><StackPanel HorizontalAlignment="Center" Spacing="4"><StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"><TextBlock Text="{Binding RoleIcon}" FontSize="14"/><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12" Foreground="#E0E0E0"/><Border CornerRadius="7" Background="#D0021B" MinWidth="14" Height="14" Padding="3,0" VerticalAlignment="Top" Margin="-2,-4,0,0" IsVisible="{Binding HasUnread}"><TextBlock Text="{Binding UnreadBadge}" FontSize="8" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></StackPanel><Border Padding="4,2" CornerRadius="3" HorizontalAlignment="Center" Background="{Binding GlowColor}"><StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"><Border Width="6" Height="6" CornerRadius="3" Background="{Binding StatusColor}" Classes="pulse"/><TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="#CCC"/></StackPanel></Border><TextBlock Text="{Binding Model}" FontSize="10" Foreground="#556" HorizontalAlignment="Center" FontFamily="Consolas,monospace"/><TextBlock Text="{Binding CurrentTask}" FontSize="9" Foreground="#778" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="140" IsVisible="{Binding CurrentTask, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/></StackPanel></Border></StackPanel></StackPanel></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></ScrollViewer><Border IsVisible="{Binding IsReaderOpen}" Background="#CC0D0D1A" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"><Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20" CornerRadius="12" Background="#1E1E3A" BorderThickness="1" BorderBrush="#4A90D9" MinWidth="400" MaxWidth="600" MaxHeight="400"><DockPanel><DockPanel DockPanel.Dock="Top" Margin="0,0,0,12"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="{Binding ReadingBubble.KindIcon}" FontSize="16" VerticalAlignment="Center"/><TextBlock Text="{Binding ReadingBubble.SenderName}" FontSize="14" FontWeight="Bold" Foreground="#F0F0F0" VerticalAlignment="Center"/><TextBlock Text="{Binding ReadingBubble.TimeLabel}" FontSize="11" Foreground="#667" VerticalAlignment="Center" Margin="8,0,0,0"/></StackPanel><Button DockPanel.Dock="Right" Content="&#x2715;" Classes="cmd" Command="{Binding CloseReaderCommand}" HorizontalAlignment="Right" Padding="8,4"/></DockPanel><ScrollViewer><SelectableTextBlock Text="{Binding ReadingBubble.Content}" TextWrapping="Wrap" FontSize="13" Foreground="#DDD" FontFamily="Consolas,monospace" LineHeight="20"/></ScrollViewer></DockPanel></Border></Border><Border IsVisible="{Binding IsTaskInputOpen}" Background="#CC0D0D1A" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"><Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" CornerRadius="12" Background="#1E1E3A" BorderThickness="1" BorderBrush="#7ED321" MinWidth="500" MaxWidth="700" MinHeight="300"><DockPanel><DockPanel DockPanel.Dock="Top" Margin="0,0,0,12"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="&#x1F4DD;" FontSize="16" VerticalAlignment="Center"/><TextBlock Text="Assign Task to" FontSize="14" FontWeight="Bold" Foreground="#F0F0F0" VerticalAlignment="Center"/><TextBlock Text="{Binding OverlayAgent.DisplayName}" FontSize="14" FontWeight="Bold" Foreground="#7ED321" VerticalAlignment="Center" Margin="4,0,0,0"/></StackPanel><Button DockPanel.Dock="Right" Content="&#x2715;" Classes="cmd" Command="{Binding CloseOverlayCommand}" HorizontalAlignment="Right" Padding="8,4"/></DockPanel><DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0"><Button DockPanel.Dock="Right" Content="&#x25B6; Assign" Classes="cmd-primary" Command="{Binding SubmitOverlayTaskCommand}" Margin="8,0,0,0" Padding="16,10" FontSize="13"/><TextBlock Text="Write task description, then click Assign" FontSize="10" Foreground="#556" VerticalAlignment="Center"/></DockPanel><TextBox Text="{Binding OverlayTaskInput}" Classes="dark" Watermark="Describe the task in detail..." AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" MinHeight="150"/></DockPanel></Border></Border><Border IsVisible="{Binding IsMessageInputOpen}" Background="#CC0D0D1A" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"><Border HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24" CornerRadius="12" Background="#1E1E3A" BorderThickness="1" BorderBrush="#4A90D9" MinWidth="500" MaxWidth="700" MinHeight="300"><DockPanel><DockPanel DockPanel.Dock="Top" Margin="0,0,0,12"><StackPanel Orientation="Horizontal" Spacing="6"><TextBlock Text="&#x1F4AC;" FontSize="16" VerticalAlignment="Center"/><TextBlock Text="Message to" FontSize="14" FontWeight="Bold" Foreground="#F0F0F0" VerticalAlignment="Center"/><TextBlock Text="{Binding OverlayAgent.DisplayName}" FontSize="14" FontWeight="Bold" Foreground="#4A90D9" VerticalAlignment="Center" Margin="4,0,0,0"/></StackPanel><Button DockPanel.Dock="Right" Content="&#x2715;" Classes="cmd" Command="{Binding CloseOverlayCommand}" HorizontalAlignment="Right" Padding="8,4"/></DockPanel><DockPanel DockPanel.Dock="Bottom" Margin="0,12,0,0"><Button DockPanel.Dock="Right" Content="&#x1F4E8; Send" Classes="cmd-primary" Command="{Binding SubmitOverlayMessageCommand}" Margin="8,0,0,0" Padding="16,10" FontSize="13"/><TextBlock Text="Write your message, then click Send" FontSize="10" Foreground="#556" VerticalAlignment="Center"/></DockPanel><TextBox Text="{Binding OverlayMessageInput}" Classes="dark" Watermark="Write your message..." AcceptsReturn="True" TextWrapping="Wrap" FontSize="13" MinHeight="150"/></DockPanel></Border></Border></Panel></DockPanel></DockPanel></UserControl>