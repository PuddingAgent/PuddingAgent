<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:PuddingCodeDesktop.ViewModels" xmlns:m="using:PuddingCodeDesktop.Models" x:Class="PuddingCodeDesktop.Views.EditorView" x:DataType="vm:MainWindowViewModel"><DockPanel><Border DockPanel.Dock="Left" Width="240" BorderBrush="#DDD" BorderThickness="0,0,1,0"><DockPanel><Border DockPanel.Dock="Top" Padding="8" Height="200"><DockPanel><TextBlock DockPanel.Dock="Top" Text="Project" FontWeight="SemiBold" Margin="0,0,0,6"/><ListBox ItemsSource="{Binding ProjectTree}" /></DockPanel></Border><Border Padding="8"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6"><TextBlock Text="Tasks" FontWeight="SemiBold" VerticalAlignment="Center"/><Button Content="+" Command="{Binding CreateTaskCommand}" Padding="4,0" FontSize="11"/></StackPanel><ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" /></DockPanel></Border></DockPanel></Border><Border DockPanel.Dock="Right" Width="280" BorderBrush="#DDD" BorderThickness="1,0,0,0"><DockPanel><Border DockPanel.Dock="Top" Padding="8" Height="180"><DockPanel><TextBlock DockPanel.Dock="Top" Text="Log" FontWeight="SemiBold" Margin="0,0,0,6"/><Border Background="#1E1E1E" CornerRadius="4" Padding="8"><ScrollViewer><ItemsControl ItemsSource="{Binding LogEntries}"><ItemsControl.ItemTemplate><DataTemplate><SelectableTextBlock Text="{Binding}" Foreground="#CCCCCC" TextWrapping="Wrap" FontFamily="Consolas,monospace" FontSize="11"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border></DockPanel></Border></DockPanel></Border><Grid><Grid.RowDefinitions><RowDefinition Height="Auto" MinHeight="120"/><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions><TabControl Grid.Row="0" ItemsSource="{Binding OpenEditors}" SelectedIndex="{Binding SelectedEditorIndex}" MinHeight="120"><TabControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" FontSize="12"/></DataTemplate></TabControl.ItemTemplate><TabControl.ContentTemplate><DataTemplate><Border Padding="12" Background="#FAFAFA"><TextBlock Text="Code editor placeholder" Foreground="#999" VerticalAlignment="Center" HorizontalAlignment="Center"/></Border></DataTemplate></TabControl.ContentTemplate></TabControl><GridSplitter Grid.Row="1" Background="#DDD" ResizeDirection="Rows"/><Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0"><DockPanel><Border DockPanel.Dock="Bottom" Padding="8" Background="#F9F9F9" BorderBrush="#DDD" BorderThickness="0,1,0,0"><DockPanel><Button DockPanel.Dock="Right" Content="Cancel" Command="{Binding CancelAgentCommand}" IsVisible="{Binding IsBusy}" Margin="8,0,0,0" VerticalAlignment="Center"/><Button DockPanel.Dock="Right" Content="Send" Command="{Binding SendMessageCommand}" Margin="8,0,0,0" VerticalAlignment="Center"/><TextBox Text="{Binding UserInput}" Watermark="Ask PuddingCode anything..." AcceptsReturn="False" VerticalAlignment="Center"/></DockPanel></Border><ScrollViewer><ItemsControl ItemsSource="{Binding ChatMessages}" Margin="8"><ItemsControl.ItemTemplate><DataTemplate x:DataType="m:ChatEntry"><Border Margin="0,2" Padding="6,4" CornerRadius="4" Background="#F0F0F0"><SelectableTextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Consolas,monospace" FontSize="12.5"/></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></DockPanel></Border></Grid></DockPanel></UserControl>