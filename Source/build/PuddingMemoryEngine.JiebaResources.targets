<Project>
  <!--
    PuddingMemoryEngine Jieba 资源传递 Target
    确保任何引用 PuddingMemoryEngine 的项目输出目录都包含 jieba.NET 的 Resources/ 文件。
    条件：仅当 jieba.NET NuGet 包已恢复到本地缓存时执行。
  -->
  <Target Name="CopyJiebaResourcesTransitive"
          AfterTargets="Build"
          Condition="Exists('$(NuGetPackageRoot)jieba.net\0.42.2\Resources')">

    <PropertyGroup>
      <_JiebaNuGetResources>$(NuGetPackageRoot)jieba.net\0.42.2\Resources</_JiebaNuGetResources>
    </PropertyGroup>

    <ItemGroup>
      <_JiebaResourceFiles Include="$(_JiebaNuGetResources)\**\*" />
    </ItemGroup>

    <Copy SourceFiles="@(_JiebaResourceFiles)"
          DestinationFolder="$(OutputPath)Resources\%(RecursiveDir)"
          SkipUnchangedFiles="true"
          Condition="'@(_JiebaResourceFiles)' != ''" />

    <Message Importance="low"
             Text="[PuddingMemoryEngine] Jieba Resources 已复制到 $(OutputPath)Resources\ (%(_JiebaResourceFiles.RecursiveDir) 个文件)" />
  </Target>

</Project>
