# ============================================================
# Pudding Agent Network — 环境变量配置示例
# ============================================================
# 使用方法：复制本文件为 .env 并填写真实值
#   cp .env.example .env

# ── LLM 配置（必填）────────────────────────────────────────────
# OpenAI:    LLM_ENDPOINT=https://api.openai.com  LLM_MODEL=gpt-4o-mini
# DeepSeek:  LLM_ENDPOINT=https://api.deepseek.com  LLM_MODEL=deepseek-chat
# Ollama:    LLM_ENDPOINT=http://host.docker.internal:11434/v1  LLM_MODEL=llama3
LLM_ENDPOINT=https://api.openai.com
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# ── 数据库 ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=pudding_dev

# ── 消息队列 ────────────────────────────────────────────────────
RABBITMQ_PASSWORD=pudding_dev

# ── ASP.NET Core 环境 ───────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── 对外端口 ────────────────────────────────────────────────────
HTTP_PORT=80
