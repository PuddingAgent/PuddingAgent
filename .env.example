# ============================================================
# Pudding Agent Network — 环境变量配置示例
# ============================================================
# 使用方法：复制本文件为 .env 并填写真实值
#   cp .env.example .env

# ── LLM 配置（必填）────────────────────────────────────────────
# OpenAI:    LLM_ENDPOINT=https://api.openai.com/v1  LLM_MODEL=gpt-4o-mini
# DeepSeek:  LLM_ENDPOINT=https://api.deepseek.com/v1  LLM_MODEL=deepseek-chat
# Ollama:    LLM_ENDPOINT=http://host.docker.internal:11434/v1  LLM_MODEL=llama3
LLM_ENDPOINT=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# ── 数据库 ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=pudding_dev

# ── JWT 鉴权（必填）────────────────────────────────────────────
# 生产环境必须替换为高强度随机密钥（≥ 32 字符）
# 生成命令：openssl rand -base64 48
JWT_KEY=Pudding-Platform-JWT-DevKey-MUST-CHANGE-IN-PRODUCTION-32PLUS!

# ── 消息队列 ────────────────────────────────────────────────────
RABBITMQ_PASSWORD=pudding_dev

# ── MinIO 对象存储（Skill 包存储）───────────────────────────────
# Web 控制台：http://localhost:9001  S3 API：http://localhost:9000
MINIO_ROOT_USER=pudding
MINIO_ROOT_PASSWORD=pudding_dev_minio

# ── ASP.NET Core 环境 ───────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── 对外端口 ────────────────────────────────────────────────────
HTTP_PORT=80
